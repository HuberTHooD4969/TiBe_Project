# === TiBe Deployment Configuration ===
# Copy this to .env and fill in your values

# Security (REQUIRED - generate a random string)
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production

# Paystack (REQUIRED for payments)
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxx

# Google OAuth (optional - for Google login)
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Apple OAuth (optional - for Apple login)
APPLE_CLIENT_ID=com.example.service
APPLE_TEAM_ID=xxxxxxxxxx
APPLE_KEY_ID=xxxxxxxxxx
APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey.p8

# Video Processing
MAX_FRAME_WORKERS=4

# Free Tier Ads
AD_WATCH_DURATION_SECONDS=30
AD_WATCH_COOLDOWN_MINUTES=60

# Pricing (JSON array, customize as needed)
# PRICING_PLANS=[{"name":"Starter","units":10,"price_cents":999,"popular":false},{"name":"Pro","units":30,"price_cents":2499,"popular":true},{"name":"Ultra","units":100,"price_cents":6999,"popular":false}]
